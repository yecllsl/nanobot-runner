#!/bin/sh
# Git pre-commit hook for RunFlowAgent
# 跨平台兼容的预提交钩子

set -e

# 强制 Python 使用 UTF-8 输出，解决 Windows GBK 编码问题
export PYTHONUTF8=1
export PYTHONIOENCODING=utf-8

echo "🔍 Git Hook: 开始预提交检查..."

# 设置环境变量，标识这是 Git Hook 模式
export GIT_HOOK=1

# 切换到项目根目录
cd "$(git rev-parse --show-toplevel)"

# 检查是否在项目根目录
if [ ! -f "pyproject.toml" ]; then
    echo "❌ 错误: 请在项目根目录执行 git commit"
    exit 1
fi

# 检查预提交检查脚本是否存在
if [ ! -f "scripts/pre-commit-check.py" ]; then
    echo "⚠️  警告: 预提交检查脚本不存在，跳过检查"
    exit 0
fi

# 检查 uv 是否可用
if ! command -v uv > /dev/null 2>&1; then
    echo "❌ 错误: uv 命令未找到，请安装 uv"
    echo "💡 安装方法: pip install uv 或访问 https://docs.astral.sh/uv/"
    exit 1
fi

# 执行预提交检查
echo "📋 执行预提交检查..."
if uv run python scripts/pre-commit-check.py; then
    echo "✅ 预提交检查通过，允许提交"
    exit 0
else
    echo ""
    echo "🚫 预提交检查失败，请修复问题后重新提交"
    echo ""
    echo "💡 提示:"
    echo "  1. 查看上方错误信息，修复对应问题"
    echo "  2. 可以手动运行: uv run python scripts/pre-commit-check.py"
    echo "  3. 跳过检查（不推荐）: git commit --no-verify"
    echo ""
    exit 1
fi
